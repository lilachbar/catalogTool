{
  "name": "catalog-tool",
  "private": true,
  "type": "module",
  "scripts": {
    "build:chat": "esbuild catalog_tool/web/src/chat-client.jsx --bundle --outfile=catalog_tool/web/static/chat.bundle.js --format=esm --jsx=automatic --loader:.jsx=jsx",
    "chat-server": "node server/index.js",
    "build": "npm run build:chat",
