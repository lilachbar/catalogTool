# Chat provider: cursor (recommended) or openai
# Auto-detects: cursor if CURSOR_API_KEY is set, else openai if OPENAI_API_KEY is set
CHAT_PROVIDER=cursor

# Cursor user API key — server-side only (cursor.com/dashboard → API Keys)
# Format: crsr_ + long secret (shown only once). Example: crsr_abc123...e6c4
CURSOR_API_KEY=crsr_...

# Cursor model (default: composer-2.5)
# CURSOR_MODEL=composer-2.5

# OpenAI — only needed when CHAT_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Optional: catalogone MCP env (otherwise loaded from ~/.cursor/mcp.json)
# C1_APIGW_URL=https://amd-apigw-...
# C1_WEB_UI_URL=https://c1-web-ui-...
# C1_USERNAME=
# C1_PASSWORD=
# C1_KEYCLOAK_URL=
# C1_KEYCLOAK_REALM=
# CATALOGONE_MCP_PATH=/Users/you/.mcp-servers/catalogone-mcp/dist/index.js

# Internal chat server port (Flask proxies /api/chat here)
CHAT_SERVER_PORT=3001
