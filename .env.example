# Catalog Tool — copy to .env and fill in values
# cp .env.example .env

# --- Chat provider (required for AI chat) ---
# Create CURSOR_API_KEY at https://cursor.com/dashboard/integrations (format crsr_...)
CHAT_PROVIDER=cursor
CHAT_MODE=agent
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5

# Option B: OpenAI
# CHAT_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Option C: Claude (Anthropic)
# CHAT_PROVIDER=claude
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Web server ---
PORT=8080
WEB_SERVER_HOST=127.0.0.1
FLASK_DEBUG=false
# Required when WEB_SERVER_HOST=0.0.0.0 — generate with: openssl rand -hex 32
# FLASK_SECRET_KEY=
CHAT_SERVER_PORT=3001
CHAT_SERVER_HOST=127.0.0.1
NO_PROXY=*.corp.amdocs.com,localhost,127.0.0.1

# --- Amdocs LDAP (application login gate) ---
# USE_LDAP toggles the LDAP login page. Default is false: no login page is shown.
# Set USE_LDAP=true to require an Amdocs LDAP sign-in before the UI loads.
# (Legacy LDAP_AUTH_ENABLED is still honored as a fallback if USE_LDAP is unset.)
USE_LDAP=false
LDAP_URI=ldap://corp.amdocs.com:389
LDAP_DOMAIN=corp.amdocs.com
# upn (default): user@corp.amdocs.com | sam: CORP\user | dn: LDAP_BIND_DN_TEMPLATE
LDAP_BIND_FORMAT=upn
# LDAP_BIND_DN_TEMPLATE=CN={username},OU=Users,DC=corp,DC=amdocs,DC=com
LDAP_USE_SSL=false
LDAP_TLS=true
LDAP_RECEIVE_TIMEOUT=10
