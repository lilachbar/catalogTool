# Example nginx reverse proxy for Catalog Tool (optional).
# Terminates TLS and forwards to Flask on localhost:8080.
#
# 1. Copy to your nginx sites (adjust server_name and SSL paths).
# 2. Start the app: WEB_SERVER_HOST=127.0.0.1 ./scripts/run_web.sh
# 3. Reload nginx.

upstream catalog_tool_web {
    server 127.0.0.1:8080;
    keepalive 8;
}

server {
    listen 443 ssl http2;
    server_name catalog-tool.example.corp.amdocs.com;

    # ssl_certificate     /path/to/fullchain.pem;
    # ssl_certificate_key /path/to/privkey.pem;

    client_max_body_size 16m;

    location / {
        proxy_pass http://catalog_tool_web;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        proxy_buffering off;
    }
}

server {
    listen 80;
    server_name catalog-tool.example.corp.amdocs.com;
    return 301 https://$host$request_uri;
}
